# ==============================================================================
# .dockerignore — Hugo Docker 빌드 컨텍스트 제외 목록
# ==============================================================================
# Why: COPY . . 실행 시 불필요한 파일이 빌드 컨텍스트에 포함되면
#      Docker daemon으로의 전송 시간이 늘어남
#      제외 대상: Hugo 빌드 출력물, 개발 도구, Git 메타데이터
# ==============================================================================

# Git 메타데이터 (빌드에 불필요)
.git
.gitignore

# Hugo 빌드 출력물 (builder 스테이지에서 새로 생성)
public/
resources/

# 개발 문서 (정적 사이트 내용 아님)
docs/
.github/
.claude/
archive/
jiminfolder/

# 개발 스크립트
*.sh
deploy.sh
private_deploy.sh

# 로그 및 임시 파일
*.log
*.backup
*.bak

# Node modules (Hugo pipes 미사용)
node_modules/

# IDE
.vscode/
.idea/
